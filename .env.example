# LLM — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxx
LLM_MODEL=anthropic/claude-sonnet-4-5

# Database
DUCKDB_PATH=data/processed/edan.duckdb

# RAG
CHROMA_PERSIST_DIR=data/processed/chroma

# App
STREAMLIT_PORT=8501
FASTAPI_PORT=8090
FASTAPI_URL=http://api:8090

# Guardrails SQL
SQL_TIMEOUT_SECONDS=10
SQL_MAX_LIMIT=1000
SQL_DEFAULT_LIMIT=100

# Observabilité (Level 4) — traces écrites dans data/traces/traces.jsonl
# Mettre à true pour activer, false (ou absent) pour désactiver
ENABLE_TRACING=false
